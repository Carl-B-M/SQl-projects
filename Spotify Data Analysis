--This project demonstrates how to create a table and download data to it
--table data downloaded was  Spotify data from Kaggle
--last section shows a few analytical queries that wereperformed.



--table creation

CREATE TABLE BIT_DB.Spotifydata (
id integer PRIMARY KEY,
artist_name varchar NOT NULL,
track_name varchar NOT NULL,
track_id varchar NOT NULL,
popularity integer NOT NULL,
danceability decimal(4,3) NOT NULL,
energy decimal(4,3) NOT NULL,
song_key integer NOT NULL,
loudness decimal(5,3) NOT NULL,
song_mode integer NOT NULL,
speechiness decimal(5,4) NOT NULL,
acousticness decimal(6,5) NOT NULL,
instrumentalness decimal(8,7) NOT NULL,
liveness decimal(5,4) NOT NULL,
valence decimal(4,3) NOT NULL,
tempo decimal(6,3) NOT NULL,
duration_ms integer NOT NULL,
time_signature integer NOT NULL )
;



SELECT BIT_DB.Spotifydata.id
FROM 
BIT_DB.Spotifydata
;



--Q1 what is the top 5 most popular acoustic songs
SELECT 
BIT_DB.Spotifydata.artist_name
,BIT_DB.Spotifydata.track_name
,BIT_DB.Spotifydata.acousticness
FROM
BIT_DB.Spotifydata
WHERE BIT_DB.Spotifydata.acousticness >0.6
ORDER BY BIT_DB.Spotifydata.popularity desc 
LIMIT 5
;

--Q2 list the top 10 most popular songs
SELECT 
BIT_DB.Spotifydata.artist_name
,BIT_DB.Spotifydata.track_name
,BIT_DB.Spotifydata.tempo

,(BIT_DB.Spotifydata.danceability/(SELECT max(BIT_DB.Spotifydata.danceability)FROM BIT_DB.Spotifydata))*100 as danceability_percentage
,(BIT_DB.Spotifydata.tempo/(SELECT max(BIT_DB.Spotifydata.tempo)FROM BIT_DB.Spotifydata))*100 as tempo_percentage
FROM
BIT_DB.Spotifydata

WHERE ((BIT_DB.Spotifydata.danceability/(SELECT max(BIT_DB.Spotifydata.danceability)FROM BIT_DB.Spotifydata))*100)>80
ORDER BY BIT_DB.Spotifydata.popularity desc
LIMIT 10
;

--Q3 FInd the top 10 most popular songs with the highest danceability and compare it to the tempo of the song
SELECT 
BIT_DB.Spotifydata.artist_name
,BIT_DB.Spotifydata.track_name
FROM
BIT_DB.Spotifydata
;

--Q4 List the top 5 most popular artist
SELECT 
BIT_DB.Spotifydata.artist_name
FROM
BIT_DB.Spotifydata
GROUP BY BIT_DB.Spotifydata.artist_name
ORDER BY BIT_DB.Spotifydata.popularity desc 
LIMIT 5
;