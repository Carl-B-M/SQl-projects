
--Q1 How many many unique orders were placed in January? 
SELECT COUNT(distinct BIT_DB.JanSales.orderID)
FROM BIT_DB.JanSales
;

--Q2 How many of those orders were for an iPhone
SELECT COUNT(distinct BIT_DB.JanSales.orderID)
FROM BIT_DB.JanSales
WHERE BIT_DB.JanSales.Product Like "%iphone%"
;



--Q3 Select the customer account numbers for all the orders that were placed in February
SELECT  distinct BIT_DB.customers.acctnum
FROM BIT_DB.FebSales
INNER Join BIT_DB.customers
ON BIT_DB.FebSales.orderID = BIT_DB.customers.order_id
WHERE length(orderid) = 6
AND orderid <> 'Order ID';


--Q4 Which product was the cheapest one sold in January, and what was the price?
SELECT MIN( BIT_DB.JanSales.price) as "loweat_price", BIT_DB.JanSales.Product
FROM BIT_DB.JanSales
;

--Q5 What is the total revenue for each product sold in January?
SELECT  BIT_DB.JanSales.Product, sum(Quantity) As total_sold, sum(Quantity)*price AS rev
FROM BIT_DB.JanSales
GROUP By BIT_DB.JanSales.Product

;


--Q6 Which products were sold in February at 548 Lincoln St, Seattle, WA 98101, how many of each were sold, and what was the total revenue?
SELECT  BIT_DB.FebSales.location, product, Quantity, sum(Quantity)*price AS rev
FROM BIT_DB.FebSales
WHERE location LIKE "%548 Lincoln St, Seattle%"
GROUP BY product
;


--Q7 How many customers ordered more than 2 products at a time in February, and what was the average amount spent for those customers?
