-- Answer A: this will return the results for any distinct customer that ordered more than 2 of a single product but wont account for clients that perchused more than two seperate products
SELECT
--count( cust.acctnum),
count(distinct cust.acctnum),
avg(quantity*price)
FROM BIT_DB.FebSales Feb
LEFT JOIN BIT_DB.customers cust
ON Feb.orderid=cust.order_id
WHERE Feb.Quantity>2
AND length(orderid) = 6
AND orderid <> 'Order ID';
;


--Answer B: this will group all of the clients that bought more than two of any product combined but shows them seperatly
SELECT
COUNT(distinct Cust.acctnum)
,AVG(Feb.Quantity*Feb.price) as average_spent
,SUM(Feb.Quantity)
,COUNT(Feb.Product)
From BIT_DB.FebSales Feb
LEFT JOIN BIT_DB.customers Cust
ON Feb.orderID = Cust.order_id
GROUP BY Cust.acctnum 
HAVING SUM(Feb.Quantity)>2 
;


-- Answer: this uses the results of answer B and returns the number of clients that bought more than 2 products in feb and returns the avergae price spent
SELECT
COUNT(distinct BIT_DB.customers.acctnum) AS Cust_with_more_than_two_items
,AVG(BIT_DB.FebSales.Quantity*BIT_DB.FebSales.price) as average_spent
,SUM(BIT_DB.FebSales.Quantity)

FROM BIT_DB.FebSales
LEFT JOIN BIT_DB.customers
ON BIT_DB.FebSales.orderID = BIT_DB.customers.order_id

WHERE BIT_DB.customers.acctnum IN 
(SELECT distinct BIT_DB.customers.acctnum 
FROM BIT_DB.FebSales
LEFT JOIN BIT_DB.customers
ON BIT_DB.FebSales.orderID = BIT_DB.customers.order_id
GROUP BY BIT_DB.customers.acctnum
HAVING SUM(BIT_DB.FebSales.Quantity)>2) 
;